# 資料庫
DATABASE_URL=sqlite:///./auto_draw.db

# ComfyUI
COMFYUI_BASE_URL=http://127.0.0.1:8188
COMFYUI_WS_URL=ws://127.0.0.1:8188/ws

# 輸出目錄
OUTPUT_DIR=./outputs
GALLERY_DIR=./outputs/gallery

# LoRA 訓練
LORA_TRAIN_DIR=./lora_train
LORA_TRAIN_THRESHOLD=10
LORA_DEFAULT_CHECKPOINT=
LORA_SDXL=false
LORA_AUTO_PROMPT=1girl, solo, high quality
SD_SCRIPTS_PATH=./sd-scripts
# WD Tagger 需 cv2/torch，請填 Kohya venv 的 python.exe；未填則用系統 python
SD_SCRIPTS_PYTHON=
# LoRA 訓練參數預設值（API 未帶入時使用）
LORA_RESOLUTION=512
LORA_BATCH_SIZE=4
LORA_LEARNING_RATE=1e-4
LORA_CLASS_TOKENS=sks
LORA_KEEP_TOKENS=1
LORA_NUM_REPEATS=10
LORA_MIXED_PRECISION=fp16
LORA_NETWORK_DIM=16
LORA_NETWORK_ALPHA=16
LORA_SAVE_EVERY_N_EPOCHS=1

# watchdog 監聽目錄（逗號分隔）
WATCH_DIRS=./lora_train

# MCP Server（供 Cursor 整合）
MCP_BACKEND_API_URL=http://127.0.0.1:8000
