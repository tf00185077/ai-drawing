# This file contains Docker-safe defaults. setup.ps1/setup.sh generates .env.
COMFYUI_MODE=disabled
COMFYUI_BASE_URL=
COMFYUI_WS_URL=
COMFYUI_CHECKPOINTS_DIR=/comfyui/models/checkpoints
COMFYUI_LORAS_DIR=/comfyui/models/loras
COMFYUI_DIFFUSION_MODELS_DIR=/comfyui/models/diffusion_models
COMFYUI_TEXT_ENCODERS_DIR=/comfyui/models/text_encoders
COMFYUI_VAE_DIR=/comfyui/models/vae
COMFYUI_EMBEDDINGS_DIR=/comfyui/models/embeddings
COMFYUI_CONTROLNET_DIR=/comfyui/models/controlnet
COMFYUI_UPSCALE_MODELS_DIR=/comfyui/models/upscale_models
COMFYUI_INPUT_DIR=/comfyui/input

DATABASE_URL=sqlite:////data/database/auto_draw.db
OUTPUT_DIR=/data/outputs
GALLERY_DIR=/data/gallery
PROMPT_LIBRARY_DIR=/data/prompt_library
LORA_TRAIN_DIR=/data/lora_train
WATCH_DIRS=/data/lora_train

# LoRA training checkpoint resolution:
# A bare checkpoint filename is resolved by searching LORA_CHECKPOINT_DIRS first,
# then the family-specific ComfyUI dir — COMFYUI_CHECKPOINTS_DIR for SD/SDXL and
# COMFYUI_DIFFUSION_MODELS_DIR for Anima. LORA_CHECKPOINT_DIRS is therefore
# optional: leave it empty to rely on the ComfyUI dirs above. Absolute paths and
# HuggingFace ids are always accepted as-is.
# LORA_CHECKPOINT_DIRS=
# Anima (diffusion-model family) components; may also be passed per-request.
# Absolute paths or bare filenames (resolved under the ComfyUI dirs above).
# LORA_ANIMA_QWEN3=
# LORA_ANIMA_VAE=
# LORA_ANIMA_T5_TOKENIZER_PATH=

# Host-facing Backend endpoint (for MCP clients and local tools).
MCP_BACKEND_API_URL=http://127.0.0.1:8001
BACKEND_PORT=8001
FRONTEND_PORT=5173

# CIVITAI_AUTHORIZATION=YOUR_CIVITAI_API_KEY
