# 資料庫
DATABASE_URL=sqlite:///./auto_draw.db

# ComfyUI
COMFYUI_BASE_URL=http://127.0.0.1:8188
# 模型目錄，用於 Slack !查可用資源
COMFYUI_CHECKPOINTS_DIR=D:/AI/ComfyUI/models/checkpoints
COMFYUI_LORAS_DIR=D:/AI/ComfyUI/models/loras
COMFYUI_WS_URL=ws://127.0.0.1:8188/ws
# 監聽 ComfyUI 直接生成：從 UI 產圖時自動記錄至圖庫（true/false）
COMFYUI_RECORD_EXTERNAL=true
# 輪詢間隔（秒）
COMFYUI_HISTORY_POLL_INTERVAL=10

# 輸出目錄
OUTPUT_DIR=./outputs
GALLERY_DIR=./outputs/gallery

# LoRA 訓練
LORA_TRAIN_DIR=./lora_train
LORA_TRAIN_THRESHOLD=10
LORA_DEFAULT_CHECKPOINT=
# 純檔名 checkpoint 的前綴路徑，如 model.safetensors → {此路徑}/model.safetensors
LORA_CHECKPOINT_DIRS=D:/AI/ComfyUI/models/checkpoints
LORA_SDXL=false
LORA_AUTO_PROMPT=1girl, solo, high quality
SD_SCRIPTS_PATH=./sd-scripts
# WD Tagger 需 cv2/torch，請填 Kohya venv 的 python.exe；未填則用系統 python
SD_SCRIPTS_PYTHON=
# WD 後處理：caption 最多保留幾個 tag、trigger word 前綴（如 class token ohwx）
WD_TAG_LIMIT=15
WD_TRIGGER_WORD=
# LoRA 訓練參數預設值（API 未帶入時使用）
LORA_RESOLUTION=512
LORA_BATCH_SIZE=4
LORA_LEARNING_RATE=1e-4
LORA_CLASS_TOKENS=sks
LORA_KEEP_TOKENS=1
LORA_NUM_REPEATS=10
LORA_MIXED_PRECISION=fp16
LORA_NETWORK_DIM=16
LORA_NETWORK_ALPHA=16
LORA_SAVE_EVERY_N_EPOCHS=1

# watchdog 監聽目錄（逗號分隔）
WATCH_DIRS=./lora_train

# ControlNet 預設姿態圖（路徑相對於專案根目錄，未指定 image_pose 時使用）
CONTROLNET_DEFAULT_POSE_IMAGE=backend/lora_train/lovelive/__asaka_karin_love_live_and_1_more_drawn_by_nasuno_nasuno42__sample-363e09661ab550cd5a85bbc226caf34e.jpg

# MCP Server（供 Cursor 整合）
MCP_BACKEND_API_URL=http://127.0.0.1:8000

# 遠端觸發生圖（Slack Socket Mode）
SLACK_APP_TOKEN=xapp-xxx
SLACK_BOT_TOKEN=xoxb-xxx
# Slack handler 呼叫 Backend 用，Backend 不在本機時可覆寫
# INTERNAL_API_BASE_URL=http://127.0.0.1:8000
