{
  "1": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "anypose_space_high_lunge_andrew_clark.jpg"
    },
    "_meta": {"title": "Load public high-lunge pose reference"}
  },
  "2": {
    "class_type": "DWPreprocessor",
    "inputs": {
      "image": ["1", 0],
      "detect_hand": "enable",
      "detect_body": "enable",
      "detect_face": "enable",
      "resolution": 1024,
      "bbox_detector": "yolox_l.onnx",
      "pose_estimator": "dw-ll_ucoco_384_bs5.torchscript.pt",
      "scale_stick_for_xinsr_cn": "disable"
    },
    "_meta": {"title": "DWPose Estimator"}
  },
  "3": {
    "class_type": "SaveImage",
    "inputs": {
      "images": ["2", 0],
      "filename_prefix": "anypose_space_high_lunge_dwpose_skeleton"
    },
    "_meta": {"title": "Save DWPose skeleton"}
  }
}
